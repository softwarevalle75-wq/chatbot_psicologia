# ============================================================
# ChatBot Psicología — Variables de Entorno
# ============================================================
# Copia este archivo como .env y completa los valores.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# ── Entorno ──────────────────────────────────────────────────
# Valores: development | production
NODE_ENV=development

# ── Base de datos MySQL (aplicación principal) ───────────────
DATABASE_URL=mysql://root:password@localhost:3306/chatbot_psico
MYSQL_DB_HOST=localhost
MYSQL_DB_PORT=3306
MYSQL_DB_USER=root
MYSQL_DB_PASSWORD=
MYSQL_DB_NAME=chatbot_psico

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
WEB_PORT=3008
WEB_HOST=localhost

# ── Dominio / IP donde corre la aplicación ───────────────────
IP_DOMAIN=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────
# Lista separada por comas de orígenes permitidos.
# En producción, si no se configura, se rechazan TODAS las peticiones cross-origin.
# Ejemplo: https://mi-frontend.com,https://admin.mi-app.com
CORS_ORIGINS=
FRONTEND_ORIGIN=

# ── Seguridad JWT ────────────────────────────────────────────
# OBLIGATORIO. Mínimo 16 caracteres. Genera uno seguro:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Qdrant (Vector DB para RAG) ─────────────────────────────
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=rag-psicologia

# ── Embeddings ───────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=1536

# ── Bot WhatsApp / Números ───────────────────────────────────
# Número del bot (con prefijo de país, ej: 573001234567)
BOT_NUM=
# Número del primer administrador
PRIMER_ADMIN=
# Teléfono admin adicional (fallback para notificaciones)
ADMIN_PHONE=

# ── Administradores Web ──────────────────────────────────────
# Correos de administradores separados por coma (además del hardcoded chatbotpsicologia@gmail.com)
ADMIN_EMAILS=

# ── Correo SMTP (Gmail u otro) ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── PDFs ─────────────────────────────────────────────────────
# Destino del PDF de informe: practitioner | patient | both
PDF_TARGET=practitioner

# ── Tests psicológicos ───────────────────────────────────────
# Umbral de puntaje alto para GHQ-12 (default: 12)
GHQ12_HIGH_THRESHOLD=12

# ── Base de datos de Producción (solo para sync_prod_to_local.js) ─
# NO son necesarias para ejecutar la aplicación.
PROD_DB_HOST=
PROD_DB_PORT=
PROD_DB_USER=
PROD_DB_PASSWORD=
PROD_DB_NAME=
