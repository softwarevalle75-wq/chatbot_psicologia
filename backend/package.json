{
  "name": "@chatbot-psico/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx watch src/app.ts",
    "dev:bot": "tsx watch src/bot/app.ts",
    "start:api": "node dist/app.js",
    "start:bot": "node dist/bot/app.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "prisma:generate": "prisma generate --schema ../database/schema/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema ../database/schema/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@builderbot/bot": "1.2.2",
    "@builderbot/database-mysql": "1.2.2",
    "@builderbot/provider-baileys": "1.2.2",
    "@formkit/tempo": "^0.1.2",
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.2",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.77.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "8.57.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
